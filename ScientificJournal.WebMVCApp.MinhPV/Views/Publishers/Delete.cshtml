@model Publisher

@{
    ViewData["Title"] = "Delete Publisher";
}

<h1>Delete Publisher</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<h4>Are you sure you want to delete this?</h4>
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.PublisherName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.PublisherName)</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Country)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Country)</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="PublisherId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
