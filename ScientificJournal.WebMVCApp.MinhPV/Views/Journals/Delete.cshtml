@model JournalsMinhPv

@{
    ViewData["Title"] = "Delete Journal";
}

<h1>Delete Journal</h1>

<div asp-validation-summary="ModelOnly" class="text-danger"></div>
<h4>Are you sure you want to delete this?</h4>
<dl class="row">
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.JournalName)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.JournalName)</dd>
    <dt class="col-sm-3">Publisher</dt>
    <dd class="col-sm-9">@Model.Publisher?.PublisherName</dd>
    <dt class="col-sm-3">@Html.DisplayNameFor(model => model.Issn)</dt>
    <dd class="col-sm-9">@Html.DisplayFor(model => model.Issn)</dd>
</dl>

<form asp-action="Delete">
    <input type="hidden" asp-for="JournalIdMinhPv" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <button type="button" id="btnHubDeleteJournal" class="btn btn-warning">Delete via Hub</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>

@section Scripts {
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/scientificJournalHub")
            .build();

        connection.start().catch(function (err) {
            return console.error(err.toString());
        });

        connection.on("ReceiveJournalDeleteFailed", function (message) {
            alert(message);
        });

        document.getElementById("btnHubDeleteJournal").addEventListener("click", function (event) {
            connection.invoke("HubDeleteJournal", "@Model.JournalIdMinhPv")
                .then(function () {
                    window.location.href = '@Url.Action("Index", "Journals")';
                })
                .catch(function (err) {
                    return console.error(err.toString());
                });

            event.preventDefault();
        });
    </script>
}
