@model IEnumerable<JournalsMinhPv>

@{
    ViewData["Title"] = "Journals";
}

<h1>Journals</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Create New</a>
</p>

<table id="JournalTable" class="table table-striped table-hover">
    <thead>
        <tr>
            <th>@Html.DisplayNameFor(model => model.JournalName)</th>
            <th>Publisher</th>
            <th>@Html.DisplayNameFor(model => model.Issn)</th>
            <th>@Html.DisplayNameFor(model => model.Country)</th>
            <th>@Html.DisplayNameFor(model => model.ImpactFactor)</th>
            <th>@Html.DisplayNameFor(model => model.IsActive)</th>
            <th></th>
        </tr>
    </thead>
    <tbody id="journalTableBody">
        @foreach (var item in Model)
        {
            <tr id="journal-@item.JournalIdMinhPv">
                <td>@Html.DisplayFor(modelItem => item.JournalName)</td>
                <td>@item.Publisher?.PublisherName</td>
                <td>@Html.DisplayFor(modelItem => item.Issn)</td>
                <td>@Html.DisplayFor(modelItem => item.Country)</td>
                <td>@Html.DisplayFor(modelItem => item.ImpactFactor)</td>
                <td>@Html.DisplayFor(modelItem => item.IsActive)</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.JournalIdMinhPv">Edit</a> |
                    <a asp-action="Details" asp-route-id="@item.JournalIdMinhPv">Details</a> |
                    <a asp-action="AssignCategories" asp-route-id="@item.JournalIdMinhPv">Assign Categories</a> |
                    <a asp-action="Delete" asp-route-id="@item.JournalIdMinhPv">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    <script src="~/lib/datatables/js/jquery.dataTables.min.js"></script>
    <script src="~/js/signalr/dist/browser/signalr.min.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            const journalTable = $('#JournalTable').DataTable({
                paging: true,
                pageLength: 5,
                searching: true,
                ordering: true,
                info: true,
                autoWidth: false,
                columnDefs: [
                    { orderable: false, targets: -1 }
                ]
            });

            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/scientificJournalHub")
                .build();

            connection.start().catch(function (err) {
                return console.error(err.toString());
            });

            connection.on("ReceiveJournalCreated", function (journal) {
                if (document.getElementById(`journal-${journal.journalIdMinhPv}`)) {
                    return;
                }

                journalTable.row.add([
                    htmlEncode(journal.journalName),
                    htmlEncode(journal.publisherName),
                    htmlEncode(journal.issn),
                    htmlEncode(journal.country),
                    journal.impactFactor ?? "",
                    journal.isActive,
                    `<a href="/Journals/Edit/${journal.journalIdMinhPv}">Edit</a> |
                     <a href="/Journals/Details/${journal.journalIdMinhPv}">Details</a> |
                     <a href="/Journals/AssignCategories/${journal.journalIdMinhPv}">Assign Categories</a> |
                     <a href="/Journals/Delete/${journal.journalIdMinhPv}">Delete</a>`
                ]).draw(false);

                const rowNode = journalTable.row(':last').node();
                rowNode.id = `journal-${journal.journalIdMinhPv}`;
            });

            connection.on("ReceiveJournalDeleted", function (journalId) {
                const row = document.getElementById(`journal-${journalId}`);
                if (row) {
                    journalTable.row(row).remove().draw(false);
                }
            });

            function htmlEncode(value) {
                return $('<div/>').text(value ?? '').html();
            }
        });
    </script>
}
