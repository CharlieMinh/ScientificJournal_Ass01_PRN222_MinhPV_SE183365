@model AssignCategoriesViewModel

@{
    ViewData["Title"] = "Assign Categories";
}

<h1>Assign Categories</h1>
<h4>@Model.JournalName</h4>

<form asp-action="AssignCategories" asp-route-id="@Model.JournalId">
    <input type="hidden" asp-for="JournalId" />
    <input type="hidden" asp-for="JournalName" />

    <div class="mb-3">
        @foreach (var category in Model.Categories)
        {
            var checkboxId = $"category_{category.Value}";
            <div class="form-check">
                <input class="form-check-input"
                       type="checkbox"
                       id="@checkboxId"
                       name="SelectedCategoryIds"
                       value="@category.Value"
                       checked="@category.Selected" />
                <label class="form-check-label" for="@checkboxId">@category.Text</label>
            </div>
        }
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Details" asp-route-id="@Model.JournalId" class="btn btn-secondary">Back to Journal</a>
</form>
